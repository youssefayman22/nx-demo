{
  "name": "demo-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "app",
  "prefix": "app",
  "targets": {
    "build": {
      "executor": "nx:run-script",
      "options": {
        "script": "build"
      },
      "dependsOn": [
        {
          "projects": ["neo"],
          "target": "build"
        }
      ],
      "inputs": [
        "{projectRoot}/app/**/*",
        "{projectRoot}/public/**/*",
        "{projectRoot}/package.json",
        "{projectRoot}/next.config.ts",
        "{projectRoot}/tsconfig.json"
      ],
      "outputs": ["{projectRoot}/.next"],
      "cache": true
    },
    "dev": {
      "executor": "nx:run-script",
      "options": {
        "script": "dev"
      }
    },
    "start": {
      "executor": "nx:run-script",
      "options": {
        "script": "start"
      }
    },
    "lint": {
      "executor": "nx:run-script",
      "options": {
        "script": "lint"
      }
    }
  },
    "tags": ["scope:demo-app"]
}
